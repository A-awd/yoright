generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  phone        String?   @unique
  email        String?   @unique
  passwordHash String?
  name         String?
  role         UserRole  @default(CUSTOMER)
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bookings Booking[]
  sessions Session[]
}

enum UserRole {
  CUSTOMER
  AGENT
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model City {
  id          String   @id @default(cuid())
  code        String   @unique
  nameEn      String
  nameAr      String
  countryCode String
  countryEn   String
  countryAr   String
  timezone    String?
  heroImage   String?
  description String?
  tags        String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([countryCode])
}

model MarginRule {
  id          String    @id @default(cuid())
  name        String
  type        String
  targetId    String?
  percentage  Float
  minAmount   Float?
  maxAmount   Float?
  priority    Int       @default(0)
  isActive    Boolean   @default(true)
  validFrom   DateTime?
  validTo     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type, targetId])
}

model Booking {
  id                  String        @id @default(cuid())
  reference           String        @unique
  status              BookingStatus @default(PENDING)
  
  hotelId             String
  hotelName           String?
  hotelSnapshot       Json?
  roomId              String
  roomSnapshot        Json?
  checkIn             DateTime
  checkOut            DateTime
  nights              Int           @default(1)
  adults              Int           @default(2)
  children            Int           @default(0)
  
  netPrice            Float
  marginAmount        Float         @default(0)
  subtotal            Float
  vat                 Float
  total               Float
  currency            String        @default("SAR")
  
  supplierRef         String?
  supplierBookingData Json?
  
  userId              String?
  user                User?         @relation(fields: [userId], references: [id])
  
  guestInfo           Json
  specialRequests     String?
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  confirmedAt         DateTime?
  cancelledAt         DateTime?
  
  payments            Payment[]

  @@index([userId])
  @@index([status])
  @@index([checkIn, checkOut])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  FAILED
  REFUNDED
}

model Payment {
  id           String   @id @default(cuid())
  intentId     String   @unique
  status       String   @default("PENDING")
  
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id])
  
  amount       Float
  currency     String   @default("SAR")
  method       String?
  
  metadata     Json?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WebhookLog {
  id        String   @id @default(cuid())
  source    String
  eventType String
  payload   Json
  status    String   @default("received")
  error     String?
  createdAt DateTime @default(now())
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  metadata  Json?
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())
}
