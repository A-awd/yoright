modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_database:1.0.0", "github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "YoRight Gateway"

[[workflows.workflow]]
name = "YoRight Gateway"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build:web && npm run build:gateway && PORT=5000 node apps/gateway/dist/main.js"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[objectStorage]
defaultBucketID = "replit-objstore-b3e3d224-aa0a-4062-9f24-9485b56768d8"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
RATEHAWK_API_URL = "https://api-sandbox.worldota.net/api/b2b/v3"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=5000 node apps/gateway/dist/main.js"]
build = ["bash", "-c", "npm install && npm run build:web && npm run build:gateway"]
