{
  "name": "yoright-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "start": "node apps/gateway/dist/main.js",
    "dev": "cd apps/gateway && npm run dev",
    "build": "cd apps/gateway && npm run build",
    "build:all": "npm run build --workspaces",
    "seed": "node tools/scripts/seed.js",
    "smoke": "node tools/scripts/smoke.js",
    "test": "npm test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
