{
  "name": "yoright-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "start": "node apps/gateway/dist/main.js",
    "dev": "cd apps/gateway && npm run dev",
    "dev:web": "cd apps/web-client && npm run dev",
    "build": "npm run build:web && cd apps/gateway && npm run build",
    "build:web": "cd apps/web-client && npm run build",
    "build:gateway": "cd apps/gateway && npm run build",
    "seed": "node tools/scripts/seed.js",
    "smoke": "node tools/scripts/smoke.js"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
