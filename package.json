{
  "name": "yoright-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "start": "node apps/gateway/dist/main.js",
    "dev": "cd apps/gateway && npm run dev",
    "dev:web": "cd apps/web-client && npm run dev",
    "build": "npm run build:web && cd apps/gateway && npm run build",
    "build:web": "cd apps/web-client && npm run build",
    "build:gateway": "cd apps/gateway && npm run build",
    "build:all": "npm run build --workspaces",
    "serve:web": "npm run build && npm start",
    "seed": "node tools/scripts/seed.js",
    "smoke": "node tools/scripts/smoke.js",
    "test": "npm test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.0.3",
    "next-intl": "^4.5.3",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animate": "^1.0.7"
  }
}
